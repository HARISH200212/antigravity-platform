# ─── NestJS API ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# PostgreSQL / TimescaleDB
DATABASE_URL=postgresql://agt:agt_dev_password_2026@localhost:5432/antigravity

# Redis
REDIS_URL=redis://:agt_redis_dev@localhost:6379

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TELEMETRY_TOPIC=agt.telemetry.readings

# JWT Auth — CHANGE IN PRODUCTION (use Cloud Secret Manager)
JWT_SECRET=agt-dev-secret-CHANGE-IN-PRODUCTION-minimum-32-chars
JWT_EXPIRES_IN=8h

# ML Service URL (local dev)
ML_SERVICE_URL=http://localhost:8000

# Webhook (optional)
WEBHOOK_URL=
WEBHOOK_SECRET=whsec_dev_change_me

# ─── Next.js Frontend ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ─── Python ML Service ───────────────────────────────────────────────────────
ENVIRONMENT=development
MLFLOW_TRACKING_URI=
MODEL_ARTIFACT_URI=

